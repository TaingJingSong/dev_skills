FIGMA_ACCESS_TOKEN=replace_with_a_token_that_can_read_the_target_file

# Optional production controls
FIGMA_REQUEST_TIMEOUT_SECONDS=30
# Applies to network and 5xx failures. HTTP 429 always returns immediately.
FIGMA_REQUEST_RETRIES=3
FIGMA_CACHE_TTL_SECONDS=600
FIGMA_MAX_NODES=1500
FIGMA_MAX_TEXT_LABELS=250
FIGMA_MAX_PROMPT_INPUT_CHARS=20000
